# Service Account Email
# Ejemplo: firebase-adminsdk-abc@mi-proyecto-2025.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=your-client-email

# ============================================================================
# FIRESTORE CONFIGURATION
# ============================================================================
# Base de datos para almacenar datos del QR (plan Spark = gratis)
# Colección: registros_qr
# El QR se genera dinámicamente en el frontend desde estos datos

FIRESTORE_COLLECTION_NAME=registros_qr

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================

# URL pública donde estará disponible tu servidor.
# IMPORTANTE: para que el QR funcione desde cualquier dispositivo (fuera de tu red),
# debe ser una URL pública en internet (ejemplo: https://tu-app.onrender.com)
PUBLIC_BASE_URL=

# Solo para desarrollo local (genera QR con localhost)
# En producción/global déjalo en false o vacío.
ALLOW_LOCAL_QR=false

# development = logs detallados, errores completos
# production = logs mínimos, manejo seguro de errores
NODE_ENV=production
