# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
# 
# Obtén estas credenciales desde:
# 1. https://console.firebase.google.com/
# 2. Project Settings (⚙️) → Service Accounts
# 3. Generate New Private Key
# 4. Copia los valores del JSON descargado
#

# Project ID from Firebase Console
# Ejemplo: mi-proyecto-2025-abc123
FIREBASE_PROJECT_ID=liqui-qr

